// NOTE: This Prisma schema is migration-only.
// Runtime persistence is file-backed JSON via backend/src/db/persistence.ts.
// Do not treat this schema as an active runtime datasource.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String          @id
  username     String          @unique
  email        String          @unique
  passwordHash String
  role         String          @default("user")
  isDemo       Boolean         @default(false)
  avatarBase64 String?
  bio          String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  history             SearchHistory[]
  favorites           Favorite[]
  sharedSongs         SharedSong[]
  sharedPlaylists     SharedPlaylist[]
  sharedRecognitions  SharedRecognition[]
  playlists           Playlist[]
  achievements        Achievement[]
  apiKeys             ApiKey[]
  trackTags           TrackTag[]
}

model SearchHistory {
  id         String   @id
  userId     String
  method     String
  title      String?
  artist     String?
  album      String?
  coverUrl   String?
  recognized Boolean  @default(false)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model LegacyHistoryEntry {
  id             String   @id
  songName       String
  artist         String
  youtubeVideoId String?
  createdAt      DateTime @default(now())

  @@index([createdAt])
}

model Favorite {
  id       String   @id
  userId   String
  title    String
  artist   String
  album    String?
  coverUrl String?
  savedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, title, artist])
  @@index([userId, savedAt])
}

model SharedSong {
  id        String   @id
  shareCode String   @unique
  userId    String
  title     String
  artist    String
  album     String?
  coverUrl  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model SharedPlaylist {
  id         String   @id
  shareCode  String   @unique
  userId     String
  playlistId String
  title      String
  songCount  Int
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model SharedRecognition {
  id        String   @id
  shareCode String   @unique
  userId    String
  title     String
  artist    String
  album     String?
  coverUrl  String?
  source    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Playlist {
  id        String   @id
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracks           PlaylistTrack[]
  sharedPlaylists  SharedPlaylist[]

  @@index([userId, updatedAt])
}

model PlaylistTrack {
  id         String   @id
  playlistId String
  title      String
  artist     String
  album      String?
  coverUrl   String?
  videoId    String?
  position   Int
  addedAt    DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@unique([playlistId, title, artist])
  @@index([playlistId, position])
}

model Achievement {
  id         String   @id
  userId     String
  key        String
  unlockedAt DateTime @default(now())
  meta       Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId, unlockedAt])
}

model ApiKey {
  id        String   @id
  userId    String
  label     String
  keyPrefix String   @unique
  keyHash   String
  createdAt DateTime @default(now())
  lastUsedAt DateTime?
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model TrackTag {
  id        String   @id
  userId    String
  trackKey  String
  genre     String
  mood      String
  tempo     String
  updatedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, trackKey])
  @@index([userId, updatedAt])
}
