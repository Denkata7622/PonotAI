# Database
DATABASE_URL="file:./dev.db"

# Runtime
NODE_ENV=development
PORT=4000

# Auth
JWT_SECRET=change-me
FRONTEND_URL=http://localhost:3000

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://ponotai-production.up.railway.app
CORS_ORIGINS=http://localhost:3000

# Provider 1 (fast path): AuDD
# Free trial: https://audd.io/
AUDD_API_KEY=
AUDD_API_TOKEN=
AUDD_API_URL=https://api.audd.io/

# AI Assistant - Get free API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional for YouTube verification lookup
YOUTUBE_API_KEY=

# Optional for fallback LLM verification of noisy audio matches
HUGGINGFACE_API_KEY=
HUGGINGFACE_VISION_URL=https://router.huggingface.co/v1/chat/completions
HUGGINGFACE_VISION_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# Provider 2 (broad catalog fallback): ACRCloud
# 1) Sign up: https://console.acrcloud.com/signup
# 2) Create an "Audio & Video Recognition" project
# 3) Copy host, access_key, access_secret below
# Recommended EU host: identify-eu-west-1.acrcloud.com
ACRCLOUD_ACCESS_KEY=
ACRCLOUD_ACCESS_SECRET=
ACRCLOUD_HOST=identify-eu-west-1.acrcloud.com
ACRCLOUD_API_KEY=

# Provider 3 (degraded/noisy audio fallback): Shazam community package
# No API key required in current implementation.
SHAZAM_MOCK_RESPONSE=

# Optional recognition debug logging
RECOGNITION_DEBUG=false
