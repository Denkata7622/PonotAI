# Runtime persistence mode.
# - postgres (default): production runtime source of truth
# - file-legacy: development-only fallback for local legacy testing
PERSISTENCE_MODE=postgres

# Runtime PostgreSQL URL (required unless PERSISTENCE_MODE=file-legacy)
DATABASE_URL=postgresql://user:password@localhost:5432/trackly

# Optional override for legacy file-mode path
PONOTAI_DATA_DIR=backend/data

# Runtime
NODE_ENV=development
PORT=4000

# Auth
JWT_SECRET=change-me
ADMIN_EMAIL=owner@example.com
FRONTEND_URL=https://trackly-production.up.railway.app

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://trackly-production.up.railway.app
CORS_ORIGINS=https://trackly-production.up.railway.app,http://localhost:3000
FRONTEND_URLS=https://trackly-production.up.railway.app

# Provider 1 (fast path): AuDD
AUDD_API_KEY=
AUDD_API_TOKEN=
AUDD_API_URL=https://api.audd.io/

# AI Assistant
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Optional for YouTube verification lookup
YOUTUBE_API_KEY=

# Optional for fallback LLM verification of noisy audio matches
HUGGINGFACE_API_KEY=
HUGGINGFACE_VISION_URL=https://router.huggingface.co/v1/chat/completions
HUGGINGFACE_VISION_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# Provider 2 (broad catalog fallback): ACRCloud
ACRCLOUD_ACCESS_KEY=
ACRCLOUD_ACCESS_SECRET=
ACRCLOUD_HOST=identify-eu-west-1.acrcloud.com
ACRCLOUD_API_KEY=

# Provider 3 (degraded/noisy audio fallback): Shazam community package
SHAZAM_MOCK_RESPONSE=

# Optional recognition debug logging
RECOGNITION_DEBUG=false
