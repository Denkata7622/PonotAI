{
  "name": "ponotai-backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test tests/*.test.ts tests/**/*.test.ts",
    "test:smoke": "tsx --test tests/smoke/**/*.test.ts",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "js-yaml": "^4.1.0",
    "multer": "^1.4.5-lts.1",
    "music-metadata": "^10.6.5",
    "swagger-ui-express": "^5.0.1",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.17.24",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "overrides": {
    "music-metadata": {
      "file-type": "^18.0.0"
    }
  }
}
